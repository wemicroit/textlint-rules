{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    ":separateMultipleMajorReleases",
  ],
  osvVulnerabilityAlerts: true,
  reviewersFromCodeOwners: true,
  packageRules: [
    {
      groupName: "all patching versions",
      matchUpdateTypes: ["patch", "digest"],
      schedule: ["before 6am every weekday"],
    },
    {
      groupName: "all minor ci versions",
      matchCategories: ["ci"],
      matchUpdateTypes: ["minor"],
      schedule: ["before 6am every weekday"],
    },
    {
      matchUpdateTypes: ["minor"],
      schedule: ["before 7am on Monday"],
    },
    {
      matchUpdateTypes: ["major"],
      schedule: ["before 8am on Monday"],
    },
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Update os matrix",
      managerFilePatterns: [".github/**/**"],
      matchStrings: [
        "matrix:[\\s\\S]*os:[\\s\\S]*:",
        "os:\\s*\\n(?:\\s+-\\s+[\\w.-]+\\n)+",
        "- (?<packageName>.+?)-(?<depVersion>[0-9.]+)\\n",
      ],
      matchStringsStrategy: "recursive",
      datasourceTemplate: "github-runners",
      currentValueTemplate: "{{depVersion}}",
      depTypeTemplate: "github-runner",
    },
  ],
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 4am on Tuesday"],
  },
  labels: ["dependencies"],
}
